---
import Button from './ui/Button.astro';

const WHATSAPP_URL = 'https://wa.me/573003238106?text=Hola%2C%20me%20interesa%20conocer%20GEN.AI';

const pulseEvents = [
  { text: 'Cita confirmada — Cardiología, 9:00 AM', type: 'confirm' },
  { text: 'Recordatorio enviado — Dra. Vargas', type: 'remind' },
  { text: 'Nueva reserva vía WhatsApp — Pediatría', type: 'new' },
  { text: 'Reprogramación completada — Dr. Silva', type: 'update' },
  { text: 'Lista de espera activada — Dermatología', type: 'wait' },
  { text: 'Confirmación automática — 14 citas hoy', type: 'confirm' },
];

const doubled = [...pulseEvents, ...pulseEvents];
---

<section class="section-band relative overflow-hidden pt-32 pb-8 lg:pt-40 lg:pb-12">
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute -top-32 right-0 h-[480px] w-[480px] rounded-full bg-primary/[0.04] blur-3xl"></div>
    <div class="absolute bottom-0 -left-24 h-80 w-80 rounded-full bg-secondary/[0.06] blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 h-px w-[120%] -translate-x-1/2 bg-gradient-to-r from-transparent via-line to-transparent"></div>
  </div>

  <div class="container-custom px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:gap-20">
      <div>
        <p class="eyebrow hero-enter hero-enter-d1 mb-6">Agendamiento clínico · IA · WhatsApp · Web</p>

        <h1 class="font-display hero-enter hero-enter-d2 text-[2.35rem] leading-[1.08] font-bold tracking-tight text-ink sm:text-5xl lg:text-[3.35rem]">
          Agendamiento clínico con IA<br />
          Autoagendamiento del paciente 24/7.<br />
          <span class="text-gradient">Más ocupación. <br /> Menos costos operativos.</span>
        </h1>

        <p class="hero-enter hero-enter-d3 mt-4 max-w-lg text-base leading-relaxed text-muted sm:text-lg">
          Convierte cada cupo vacío en ingreso. Centraliza todas tus agendas en un solo panel de control,
          tus agentes cierran citas al instante y los pacientes llenan disponibilidad por WhatsApp y web
          — las 24 horas.
        </p>

        <div class="hero-enter hero-enter-d4 mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
          <Button openDemoModal variant="primary" size="lg">
            Solicitar demo
          </Button>
          <Button href={WHATSAPP_URL} variant="outline" size="lg" target="_blank" rel="noopener noreferrer">
            Escribir por WhatsApp
          </Button>
        </div>

        <dl class="hero-enter hero-enter-d4 mt-12 grid grid-cols-3 gap-4 border-t border-line pt-8 sm:gap-8">
          <div>
            <dt class="font-mono-data text-2xl font-medium text-ink sm:text-3xl">20000+</dt>
            <dd class="mt-1 text-xs text-muted sm:text-sm">Citas agendadas</dd>
          </div>
          <div>
            <dt class="font-mono-data text-2xl font-medium text-ink sm:text-3xl">48h</dt>
            <dd class="mt-1 text-xs text-muted sm:text-sm">Para implementar</dd>
          </div>
          <div>
            <dt class="font-mono-data text-2xl font-medium text-secondary sm:text-3xl">24/7</dt>
            <dd class="mt-1 text-xs text-muted sm:text-sm">Autoagendamiento</dd>
          </div>
        </dl>
      </div>

      <div id="hero-visual" class="hero-visual relative mx-auto w-full max-w-md lg:max-w-none">
        <div class="glass-panel relative overflow-hidden rounded-[1.75rem] shadow-[0_32px_80px_-24px_rgba(12,25,41,0.18)]">
          <div class="flex items-center justify-between border-b border-line/80 bg-surface-alt/50 px-5 py-3.5">
            <div class="flex gap-1.5">
              <span class="h-2.5 w-2.5 rounded-full bg-red-300"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
            </div>
            <span class="font-mono-data text-[10px] text-muted">app.genai.co</span>
          </div>

          <div class="p-5 sm:p-6">
            <div class="mb-5 flex items-end justify-between">
              <div>
                <p class="eyebrow mb-1">Agenda de hoy</p>
                <p class="font-display text-xl font-semibold text-ink">Martes, 26 jun</p>
              </div>
              <span class="rounded-full bg-secondary/10 px-3 py-1 font-mono-data text-xs font-medium text-secondary">
                32 citas
              </span>
            </div>

            <div class="mb-5 grid grid-cols-3 gap-2">
              {[
                { n: '18', l: 'Confirmadas', c: 'text-primary' },
                { n: '9', l: 'Pendientes', c: 'text-secondary' },
                { n: '5', l: 'Nuevas', c: 'text-muted' },
              ].map((s) => (
                <div class="rounded-2xl border border-line/60 bg-surface/80 p-3 text-center">
                  <p class={`font-mono-data text-xl font-medium ${s.c}`}>{s.n}</p>
                  <p class="mt-0.5 text-[10px] text-muted">{s.l}</p>
                </div>
              ))}
            </div>

            <div class="space-y-2">
              {[
                { t: '08:00', n: 'María González', e: 'Cardiología', ok: true },
                { t: '09:30', n: 'Carlos Ruiz', e: 'Medicina general', ok: true },
                { t: '11:00', n: 'Ana Torres', e: 'Pediatría', ok: false },
              ].map((apt) => (
                <div class="flex items-center gap-3 rounded-xl border border-line/50 bg-white px-3 py-2.5 transition-colors hover:border-primary/20">
                  <span class="font-mono-data text-xs text-primary">{apt.t}</span>
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-sm font-medium text-ink">{apt.n}</p>
                    <p class="truncate text-xs text-muted">{apt.e}</p>
                  </div>
                  <span class={`shrink-0 rounded-full px-2 py-0.5 text-[10px] font-medium ${apt.ok ? 'bg-secondary/10 text-secondary' : 'bg-amber-50 text-amber-700'}`}>
                    {apt.ok ? 'Confirmada' : 'Pendiente'}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="absolute -right-2 -bottom-4 w-[13.5rem] rounded-2xl border border-line bg-white p-3.5 shadow-xl sm:-right-6">
          <div class="mb-2 flex items-center gap-2">
            <div class="flex h-7 w-7 items-center justify-center rounded-full bg-[#128C7E]">
              <svg class="h-3.5 w-3.5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-ink">GEN.AI Bot</p>
              <p class="text-[10px] text-muted">ahora</p>
            </div>
          </div>
          <p class="text-xs leading-relaxed text-muted">
            Cita confirmada con Dr. Mendoza — 28 jun, 10:00 AM
          </p>
        </div>
      </div>
    </div>

    <!-- Live pulse ticker -->
    <div class="pulse-ticker" aria-label="Actividad reciente en clínicas">
      <div class="pulse-ticker-track">
        {doubled.map((event) => (
          <div class="pulse-item">
            <span class="pulse-dot" aria-hidden="true"></span>
            <span class="text-muted">{event.text}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
