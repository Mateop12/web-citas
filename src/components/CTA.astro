---
import Button from './ui/Button.astro';

interface Props {
  standalone?: boolean;
}

const { standalone = false } = Astro.props;

const WHATSAPP_URL = 'https://wa.me/573003238106?text=Hola%2C%20me%20interesa%20conocer%20GEN.AI';
---

<section {...(!standalone && { id: 'demo' })} class="section-padding">
  <div class="container-custom">
    <div
      class="relative overflow-hidden rounded-[2rem] bg-ink px-8 py-16 text-center sm:px-14 sm:py-20"
      data-animate="scale"
    >
      <div class="pointer-events-none absolute inset-0 opacity-30" aria-hidden="true">
        <div class="absolute -top-24 -right-24 h-64 w-64 rounded-full bg-primary/30 blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 h-48 w-48 rounded-full bg-secondary/20 blur-3xl"></div>
      </div>

      <div class="relative mx-auto max-w-xl">
        <p class="eyebrow mb-5 text-accent">Empieza hoy</p>
        <h2 class="font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-[2.65rem]">
          Tu clínica puede automatizar el agendamiento esta semana
        </h2>
        <p class="mt-4 text-base leading-relaxed text-white/65 sm:text-lg">
          Más de 20000 citas asiganadas gracias a nuestro aplicativo de autoagendamiento GEN.AI.
        </p>

        <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button openDemoModal variant="secondary" size="lg">
            Solicitar demo
          </Button>
          <Button
            href={WHATSAPP_URL}
            variant="outline"
            size="lg"
            class="!border-white/20 !bg-transparent !text-white hover:!border-white/40 hover:!bg-white/5"
            target="_blank"
            rel="noopener noreferrer"
          >
            Hablar por WhatsApp
          </Button>
        </div>

      </div>
    </div>
  </div>
</section>
