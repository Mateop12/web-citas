---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-1.5">
          {index > 0 && (
            <span class="text-line" aria-hidden="true">
              /
            </span>
          )}
          {
            item.href ? (
              <a href={item.href} class="transition-colors hover:text-primary">
                {item.label}
              </a>
            ) : (
              <span class="font-medium text-ink" aria-current="page">
                {item.label}
              </span>
            )
          }
        </li>
      ))
    }
  </ol>
</nav>
