---
import SectionHeader from './ui/SectionHeader.astro';

const testimonials = [
  {
    name: 'Dra. Patricia Mendoza',
    role: 'Directora Médica',
    company: 'Clínica Santa María',
    quote: 'GEN.AI transformó nuestra operación. Pasamos de 150 llamadas diarias a solo 40. Nuestro equipo de recepción ahora se dedica a atender pacientes en persona con una sonrisa.',
    initials: 'PM',
    color: 'bg-primary',
  },
  {
    name: 'Carlos Herrera',
    role: 'Gerente de Operaciones',
    company: 'Laboratorio Diagnóstico Plus',
    quote: 'La integración con WhatsApp fue un game changer. Nuestros pacientes pueden agendar análisis de laboratorio a las 11 de la noche y al día siguiente ya tienen su cita confirmada.',
    initials: 'CH',
    color: 'bg-secondary',
  },
  {
    name: 'Lic. Sandra Ruiz',
    role: 'Coordinadora Administrativa',
    company: 'IPS Salud Integral',
    quote: 'Implementamos GEN.AI en 48 horas. El ausentismo bajó un 40% en el primer mes. Los reportes nos permiten tomar decisiones basadas en datos reales.',
    initials: 'SR',
    color: 'bg-accent',
  },
  {
    name: 'Dr. Andrés Vega',
    role: 'Director',
    company: 'Centro Médico del Valle',
    quote: 'Lo que más valoro es la facilidad de uso. Mis médicos ven su agenda actualizada en tiempo real y los pacientes reciben recordatorios automáticos. Simplemente funciona.',
    initials: 'AV',
    color: 'bg-primary-dark',
  },
];
---

<section id="testimonios" class="section-padding bg-surface">
  <div class="container-custom">
    <SectionHeader
      badge="Testimonios"
      title="Voces de quienes ya automatizaron recepción"
      description="Más de 200 clínicas, IPS y laboratorios en Latinoamérica confían en GEN.AI."
    />

    <div class="mt-14 grid gap-5 sm:grid-cols-2">
      {testimonials.map((t, i) => (
        <article
          class="card-hover flex flex-col rounded-[1.25rem] border border-line bg-white p-6"
          data-animate
          data-delay={String((i % 2) + 1)}
        >
          <blockquote class="flex-1 text-sm leading-relaxed text-muted">
            "{t.quote}"
          </blockquote>

          <footer class="mt-6 flex items-center gap-3 border-t border-line pt-5">
            <div class={`flex h-10 w-10 items-center justify-center rounded-full text-xs font-semibold text-white ${t.color}`} aria-hidden="true">
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-semibold text-ink">{t.name}</p>
              <p class="text-xs text-muted">{t.role} · {t.company}</p>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
