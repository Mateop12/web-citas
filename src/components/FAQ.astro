---
import SectionHeader from './ui/SectionHeader.astro';
import { faqs } from '../data/faqs';
---

<section id="faq" class="section-padding bg-white">
  <div class="container-custom">
    <SectionHeader
      badge="Preguntas frecuentes"
      title="Respuestas directas antes de tu demo"
      description="¿No encuentras lo que buscas? Escríbenos por WhatsApp."
    />

    <div class="mx-auto mt-12 max-w-2xl divide-y divide-line border-y border-line">
      {faqs.map((faq, i) => (
        <div data-faq-item data-animate data-delay={String((i % 3) + 1)}>
          <button
            type="button"
            class="flex w-full items-center justify-between gap-4 py-5 text-left transition-colors hover:text-primary"
            data-faq-trigger
            aria-expanded="false"
          >
            <span class="text-sm font-medium text-ink sm:text-base">{faq.question}</span>
            <svg
              class="h-4 w-4 shrink-0 text-muted transition-transform duration-300"
              data-faq-icon
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </button>
          <div class="accordion-content">
            <div class="accordion-inner">
              <p class="pb-5 text-sm leading-relaxed text-muted">{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
