---
interface Props {
  badge?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
  light?: boolean;
}

const {
  badge,
  title,
  description,
  align = 'center',
  class: className = '',
  light = false,
} = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const textClass = light ? 'text-white' : 'text-ink';
const descClass = light ? 'text-white/70' : 'text-muted';
---

<div class={`max-w-3xl ${alignClass} ${className}`} data-animate>
  {
    badge && (
      <p class={`eyebrow mb-5 ${light ? 'text-accent' : ''}`}>{badge}</p>
    )
  }
  <h2 class={`font-display text-3xl leading-[1.15] font-bold tracking-tight sm:text-4xl lg:text-[2.75rem] ${textClass}`}>
    {title}
  </h2>
  {
    description && (
      <p class={`mt-5 text-base leading-relaxed sm:text-lg ${descClass}`}>{description}</p>
    )
  }
</div>
