---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { LEGAL, LEGAL_NAV } from '../data/legal';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pageTitle = `${title} | ${LEGAL.brand}`;
---

<BaseLayout title={pageTitle} description={description}>
  <Navbar />
  <main id="main-content" class="bg-surface/40 pt-28 pb-16 lg:pt-32">
    <div class="container-custom px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="eyebrow mb-4">Documentos legales</p>
        <h1 class="font-display text-3xl font-bold tracking-tight text-ink sm:text-4xl">{title}</h1>
        <p class="mt-3 text-sm text-muted">
          Última actualización: {LEGAL.lastUpdated} · {LEGAL.company} · {LEGAL.country}
        </p>

        <nav class="mt-8 flex flex-wrap gap-2" aria-label="Documentos legales relacionados">
          {
            LEGAL_NAV.map((link) => (
              <a
                href={link.href}
                class:list={[
                  'rounded-full border px-3 py-1.5 text-xs font-medium transition-colors',
                  Astro.url.pathname === link.href
                    ? 'border-primary bg-primary/10 text-primary'
                    : 'border-line bg-white text-muted hover:border-primary/30 hover:text-ink',
                ]}
              >
                {link.label}
              </a>
            ))
          }
        </nav>

        <article class="legal-prose mt-10 rounded-[1.5rem] border border-line bg-white p-6 sm:p-10">
          <slot />
        </article>

        <p class="mt-8 text-center text-sm text-muted">
          Consultas sobre privacidad y datos clínicos:
          <a href={`mailto:${LEGAL.email}`} class="font-medium text-primary hover:underline">
            {LEGAL.email}
          </a>
        </p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal-prose :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .legal-prose :global(h2:first-child) {
    margin-top: 0;
  }

  .legal-prose :global(h3) {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .legal-prose :global(p),
  .legal-prose :global(li) {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .legal-prose :global(p) {
    margin-bottom: 0.875rem;
  }

  .legal-prose :global(ul),
  .legal-prose :global(ol) {
    margin: 0.75rem 0 1rem 1.25rem;
  }

  .legal-prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .legal-prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  .legal-prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
