---
import SectionHeader from './ui/SectionHeader.astro';

const conversations = [
  {
    id: 'reservar',
    label: 'Reservar cita',
    messages: [
      { from: 'user', text: 'Hola, quiero agendar cardiología' },
      { from: 'bot', text: 'Con gusto. ¿Para qué fecha te gustaría la cita?' },
      { from: 'user', text: 'El próximo martes por la mañana' },
      { from: 'bot', text: 'Disponible:\n\nMartes 2 jul · 9:00 — Dr. Mendoza\nMartes 2 jul · 10:30 — Dra. Vargas\n\n¿Cuál prefieres?' },
      { from: 'user', text: '9:00 con Dr. Mendoza' },
      { from: 'bot', text: 'Cita confirmada\n\nCardiología · Dr. Mendoza\nMartes 2 jul, 9:00 AM\nSede Principal, Piso 3\n\nRecordatorio 24h antes.' },
    ],
  },
  {
    id: 'reprogramar',
    label: 'Reprogramar',
    messages: [
      { from: 'user', text: 'Necesito cambiar mi cita del viernes' },
      { from: 'bot', text: 'Encontré tu cita:\n\nVie 28 jun, 3:00 PM\nMedicina general — Dr. Silva\n\n¿Para qué fecha la movemos?' },
      { from: 'user', text: 'El lunes en la tarde' },
      { from: 'bot', text: 'Reprogramada:\n\nLun 1 jul, 4:30 PM · Dr. Silva\n\nLa cita anterior quedó cancelada.' },
    ],
  },
  {
    id: 'cancelar',
    label: 'Cancelar',
    messages: [
      { from: 'user', text: 'Quiero cancelar mi cita de mañana' },
      { from: 'bot', text: 'Cita encontrada:\n\nMié 27 jun, 11:00 AM\nPediatría — Dra. Ruiz\n\n¿Confirmas la cancelación?' },
      { from: 'user', text: 'Sí, confirmo' },
      { from: 'bot', text: 'Cita cancelada.\n\nEl espacio quedó disponible para otro paciente.\n\n¿Deseas agendar una nueva fecha?' },
    ],
  },
];

const patientActions = ['Reservar cita', 'Cancelar', 'Reprogramar', 'Consultar disponibilidad'];

const waSteps = [
  { label: 'Escribe', detail: 'El paciente contacta por WhatsApp' },
  { label: 'Consulta', detail: 'La IA muestra disponibilidad' },
  { label: 'Confirma', detail: 'Elige fecha y profesional' },
  { label: 'Registra', detail: 'La cita queda en tu agenda y en tu software HIS' },
];
---

<section id="whatsapp" class="section-padding bg-white">
  <div class="container-custom">
    <div class="grid gap-14 lg:grid-cols-2 lg:items-start">
      <div>
        <SectionHeader
          badge="WhatsApp"
          title="El canal que tus pacientes ya usan"
          description="Sin apps ni formularios. Conversaciones naturales que terminan en citas confirmadas."
          align="left"
        />

        <ul class="mt-8 space-y-3">
          {patientActions.map((action) => (
            <li class="flex items-center gap-3 text-sm text-muted">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-secondary/10 text-secondary">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              {action}
            </li>
          ))}
        </ul>
      </div>

      <div data-animate="fade-right">
        <div class="mb-4 flex gap-1 rounded-2xl bg-surface p-1.5" role="tablist">
          {conversations.map((conv, i) => (
            <button
              type="button"
              class={`wa-tab flex-1 ${i === 0 ? 'is-active' : ''}`}
              data-wa-tab={conv.id}
              role="tab"
            >
              {conv.label}
            </button>
          ))}
        </div>

        {conversations.map((conv, i) => (
          <div class={`wa-panel ${i === 0 ? 'is-active' : ''}`} data-wa-panel={conv.id}>
            <div class="overflow-hidden rounded-[1.5rem] border border-line shadow-[0_24px_60px_-20px_rgba(12,25,41,0.12)]">
              <div class="flex items-center gap-3 bg-[#0a5c54] px-4 py-3.5">
                <div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/15">
                  <svg class="h-4 w-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-white">GEN.AI Asistente</p>
                  <p class="text-xs text-white/60">En línea</p>
                </div>
              </div>

              <div class="space-y-2.5 bg-[#ece5dd] p-4">
                {conv.messages.map((msg) => (
                  <div class={`flex ${msg.from === 'user' ? 'justify-end' : 'justify-start'}`}>
                    <div
                      class={`max-w-[88%] rounded-2xl px-3.5 py-2 text-sm leading-relaxed ${
                        msg.from === 'user'
                          ? 'rounded-tr-md bg-[#dcf8c6] text-ink'
                          : 'rounded-tl-md bg-white text-ink shadow-sm'
                      }`}
                    >
                      <span class="whitespace-pre-line">{msg.text}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-14 border-t border-line pt-10" data-animate>
      <p class="eyebrow mb-6 text-center">Proceso por WhatsApp</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {waSteps.map((step, i) => (
          <div class="rounded-xl border border-line bg-surface/40 px-4 py-4 text-center">
            <span class="font-mono-data text-xs font-medium text-primary">{String(i + 1).padStart(2, '0')}</span>
            <p class="mt-1 text-sm font-semibold text-ink">{step.label}</p>
            <p class="mt-1 text-xs text-muted">{step.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
