---
import SectionHeader from './ui/SectionHeader.astro';

const problems = [
  {
    title: 'Llamadas perdidas',
    description: 'Cada llamada no contestada es un paciente que busca otra clínica.',
  },
  {
    title: 'Citas olvidadas',
    description: 'Sin recordatorios, el ausentismo crece y los espacios se desperdician.',
  },
  {
    title: 'Agendas saturadas',
    description: 'Coordinar horarios entre especialistas consume horas administrativas.',
  },
  {
    title: 'Carga administrativa',
    description: 'Confirmar y reprogramar a mano genera errores y retrasos.',
  },
  {
    title: 'Cancelaciones sin aviso',
    description: 'Huecos vacíos que podrían llenarse con pacientes en espera.',
  },
];
---

<section id="problema" class="section-padding border-y border-line/60 bg-white">
  <div class="container-custom">
    <SectionHeader
      badge="El problema"
      title="Agendamiento no debería ser un cuello de botella"
      description="Las clínicas comparten los mismos retos operativos. Si alguno te suena familiar, la operación manual tiene un límite."
    />

    <div class="mt-14 grid gap-px overflow-hidden rounded-[1.5rem] border border-line bg-line sm:grid-cols-2 lg:grid-cols-3">
      {problems.map((problem, i) => (
        <article
          class="card-hover bg-white p-6 sm:p-7"
          data-animate
          data-delay={String((i % 3) + 1)}
        >
          <span class="font-mono-data text-xs text-muted/70">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="mt-3 font-display text-lg font-semibold text-ink">{problem.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{problem.description}</p>
        </article>
      ))}
      <article
        class="flex flex-col justify-center bg-surface p-6 sm:col-span-2 lg:col-span-1"
        data-animate
        data-delay="3"
      >
        <p class="font-display text-xl leading-snug font-semibold text-ink">
          ¿Te identificas con más de dos?
        </p>
        <p class="mt-2 text-sm text-muted">
          Es señal de que tu agendamiento necesita automatización, no más personal en recepción.
        </p>
      </article>
    </div>
  </div>
</section>
