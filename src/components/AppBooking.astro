---
import SectionHeader from './ui/SectionHeader.astro';
import SectionMoreLink from './ui/SectionMoreLink.astro';
import { PRODUCT_PAGES } from '../data/pages-seo';

interface Props {
  standalone?: boolean;
  showMoreLink?: boolean;
  previewMode?: 'mockup' | 'screenshot';
  variant?: 'default' | 'product';
}

const {
  standalone = false,
  showMoreLink = false,
  previewMode = 'mockup',
  variant = 'default',
} = Astro.props;

const page = PRODUCT_PAGES.whatsapp;
const isProduct = variant === 'product';

const BOOKING_URL = 'https://citas.clinicagenezen.net/';
const PORTAL_SCREENSHOT = '/images/portal-citas-genezen.png';

const header = isProduct
  ? {
      badge: 'Portal web y móvil',
      title: 'Tus pacientes se autogestionan las 24 horas — sin llamar a tu entidad',
      description:
        'Un portal con la imagen de tu clínica donde el paciente filtra por EPS, especialidad, sede y médico, encuentra cupo disponible y confirma en minutos. Funciona en cualquier navegador o celular, sin descargar apps.',
    }
  : {
      badge: 'Agendamiento web',
      title: 'Portal en línea desde web o móvil',
      description:
        'El paciente filtra por EPS y especialidad, busca cupos y confirma sin llamar a tu clínica.',
    };

const steps = isProduct
  ? [
      {
        phase: 'Acceso inmediato',
        title: 'Entra desde web o celular, a cualquier hora',
        description:
          'Sin apps, sin filas ni llamadas. El paciente abre el enlace de tu clínica y empieza a agendar en segundos — incluso fuera del horario de recepción.',
      },
      {
        phase: 'Elección guiada',
        title: 'Selecciona exactamente lo que necesita',
        description:
          'EPS, especialidad, tipo de consulta, sede y médico preferido. El paciente navega con claridad y solo ve opciones válidas para su caso.',
      },
      {
        phase: 'Cupos en vivo',
        title: 'Consulta disponibilidad y reserva al instante',
        description:
          'Un clic en «Buscar disponibilidad» muestra horarios reales. Si no hay cupo, puede unirse a la lista de espera y recibir aviso automático.',
      },
      {
        phase: 'Cita confirmada',
        title: 'Registro directo en tu agenda clínica',
        description:
          'La cita queda registrada al momento, con recomendaciones que preparan al paciente y reducen ausentismo y reprocesos en recepción.',
      },
    ]
  : [
      {
        phase: 'Acceso',
        title: 'Ingresa al portal de citas',
        description:
          'Desde el navegador del celular o computador, el paciente abre el enlace de agendamiento de la clínica.',
      },
      {
        phase: 'Selección',
        title: 'Completa los filtros',
        description:
          'Elige aseguradora (EPS), especialidad, tipo de consulta, sede y médico preferido.',
      },
      {
        phase: 'Disponibilidad',
        title: 'Busca y elige horario',
        description:
          'Pulsa «Buscar disponibilidad», revisa cupos libres y selecciona fecha y hora.',
      },
      {
        phase: 'Confirmación',
        title: 'Confirma la reserva',
        description:
          'Valida datos personales, acepta recomendaciones y la cita queda registrada al instante.',
      },
    ];

const benefits = isProduct
  ? [
      'Autogestión 24/7 desde celular, tablet o computador',
      'Filtros por EPS, especialidad, sede y profesional',
      'Lista de espera automática cuando no hay cupos',
      'Confirmaciones por WhatsApp, SMS y correo',
      'Menos carga en recepción y call center',
    ]
  : [
      'Autogestión 24/7 desde celular, tablet o computador',
      'Filtros por EPS, especialidad, sede y profesional',
      'Lista de espera automática cuando no hay cupos',
      'Recomendaciones integradas que reducen ausentismo',
      'Menos carga en recepción y call center',
    ];

const recommendations = [
  'Solo un acompañante por cita médica',
  'Traer documento original, exámenes e historia clínica',
  'Llegar 30 minutos antes de la cita',
  'Portar autorización vigente de la EPS',
];
---

<section {...(!standalone && { id: 'agendamiento-web' })} class={`section-padding ${isProduct ? 'bg-white' : 'border-t border-line/60 bg-surface/50'}`}>
  <div class="container-custom">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      description={header.description}
      align={isProduct ? 'left' : 'center'}
    />

    <div class="mt-14 grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Portal preview -->
      <div class={`${isProduct ? 'order-1' : 'order-2 lg:order-1'}`} data-animate="fade-left">
        {
          previewMode === 'screenshot' ? (
            <figure class="overflow-hidden rounded-[1.75rem] border border-line bg-white shadow-[0_32px_80px_-28px_rgba(12,25,41,0.16)]">
              <img
                src={PORTAL_SCREENSHOT}
                alt="Portal de autoagendamiento clínico GEN.AI: el paciente elige EPS, especialidad, sede y médico desde web o móvil, disponible las 24 horas"
                class="h-auto w-full"
                width={1200}
                height={900}
                loading="lazy"
                decoding="async"
              />
            </figure>
          ) : (
            <div class="overflow-hidden rounded-[1.75rem] border border-line bg-white shadow-[0_32px_80px_-28px_rgba(12,25,41,0.14)]">
              <!-- Browser bar -->
              <div class="flex items-center gap-2 border-b border-line bg-surface-alt/60 px-4 py-2.5">
                <div class="flex gap-1.5">
                  <span class="h-2.5 w-2.5 rounded-full bg-red-300"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
                </div>
                <div class="mx-auto flex max-w-[16rem] flex-1 items-center gap-2 rounded-lg border border-line bg-white px-3 py-1 sm:max-w-xs">
                  <svg class="h-3 w-3 shrink-0 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  <span class="truncate font-mono-data text-[10px] text-muted">citas.clinicagenezen.net</span>
                </div>
              </div>

              <div class="p-5 sm:p-6">
                <div class="mb-5 text-center">
                  <p class="font-display text-lg font-bold text-ink sm:text-xl">Agenda tu cita</p>
                  <p class="mt-1 text-xs text-muted sm:text-sm">Agendamiento en línea · todos los días, a cualquier hora</p>
                </div>

                <div class="mb-3 grid gap-3 sm:grid-cols-2">
                  <div class="rounded-xl border border-line bg-surface/40 p-3">
                    <label class="mb-1.5 block text-[10px] font-semibold tracking-wide text-muted uppercase">Aseguradora (EPS)</label>
                    <div class="flex items-center justify-between rounded-lg border border-line bg-white px-3 py-2 text-xs text-ink">
                      <span>Sura · Contributivo</span>
                      <svg class="h-3.5 w-3.5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                    </div>
                  </div>
                  <div class="rounded-xl border border-line bg-surface/40 p-3">
                    <label class="mb-1.5 block text-[10px] font-semibold tracking-wide text-muted uppercase">Especialidad / Servicio</label>
                    <div class="flex items-center justify-between rounded-lg border border-line bg-white px-3 py-2 text-xs text-ink">
                      <span>Cardiología</span>
                      <svg class="h-3.5 w-3.5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                    </div>
                  </div>
                </div>

                <div class="mb-4 grid gap-2 sm:grid-cols-3">
                  {[
                    { label: 'Tipo de consulta *', value: 'Primera vez' },
                    { label: 'Sede', value: 'Sede principal' },
                    { label: 'Médico', value: 'Dr. Mendoza' },
                  ].map((field) => (
                    <div class="rounded-xl border border-line bg-surface/30 p-2.5">
                      <label class="mb-1 block text-[9px] font-medium text-muted">{field.label}</label>
                      <div class="flex items-center justify-between rounded-md border border-line/80 bg-white px-2 py-1.5 text-[11px] text-ink">
                        <span class="truncate">{field.value}</span>
                        <svg class="h-3 w-3 shrink-0 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                      </div>
                    </div>
                  ))}
                </div>

                <button
                  type="button"
                  class="flex w-full items-center justify-center gap-2 rounded-xl bg-secondary py-3 text-sm font-semibold text-white shadow-md shadow-secondary/25 transition-transform hover:-translate-y-0.5"
                  tabindex="-1"
                  aria-hidden="true"
                >
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                  Buscar disponibilidad
                </button>

                <div class="mt-4 rounded-xl border border-line bg-surface-alt/50 p-4">
                  <p class="mb-2 flex items-center gap-2 text-xs font-semibold text-ink">
                    <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Recomendaciones generales
                  </p>
                  <ul class="space-y-1.5">
                    {recommendations.map((item) => (
                      <li class="flex gap-2 text-[11px] leading-relaxed text-muted">
                        <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-secondary"></span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="mt-3 flex gap-2 rounded-xl border border-primary/15 bg-primary/5 p-3">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <p class="text-[11px] leading-relaxed text-muted">
                    Sin cupos activos puedes unirte a la <strong class="font-medium text-ink">lista de espera</strong> y te contactamos al liberarse un espacio.
                  </p>
                </div>
              </div>
            </div>
          )
        }

        <p class="mt-4 text-center text-xs text-muted">
          {isProduct ? 'Ejemplo en producción:' : 'Portal de referencia:'}
          <a
            href={BOOKING_URL}
            class="font-medium text-primary underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            citas.clinicagenezen.net
          </a>
        </p>

        {
          isProduct && (
            <ul class="mt-6 grid gap-3 sm:grid-cols-2">
              {benefits.map((benefit, i) => (
                <li class={`flex items-start gap-3 rounded-xl border border-line/80 bg-surface/40 px-4 py-3.5 text-sm text-muted${i === benefits.length - 1 ? ' sm:col-span-2' : ''}`}>
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  {benefit}
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <!-- Timeline -->
      <div class={`${isProduct ? 'order-2' : 'order-1 lg:order-2'}`} data-animate="fade-right">
        <p class="eyebrow mb-8">{isProduct ? 'Así funciona para tu paciente' : 'Flujo del paciente'}</p>

        <div class="relative space-y-0">
          <div class="absolute top-4 bottom-4 left-8 w-px bg-line lg:left-[2.05rem]" aria-hidden="true"></div>

          {steps.map((step, i) => (
            <article class="relative flex gap-5 pb-10 last:pb-0">
              <div class="relative z-10 flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl border border-line bg-white shadow-sm transition-all duration-300 hover:border-primary/30 hover:shadow-md">
                <span class="font-mono-data text-xs font-medium text-primary">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="pt-2">
                <p class="eyebrow mb-1">{step.phase}</p>
                <h3 class="font-display text-base font-semibold text-ink sm:text-lg">{step.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted">{step.description}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-2 rounded-full border border-line bg-white px-4 py-2 text-xs font-medium text-muted">
            <svg class="h-4 w-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Web responsive
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-line bg-white px-4 py-2 text-xs font-medium text-muted">
            <svg class="h-4 w-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
            Móvil sin app
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-line bg-white px-4 py-2 text-xs font-medium text-muted">
            <svg class="h-4 w-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Disponible 24/7
          </span>
        </div>
      </div>
    </div>

    {
      showMoreLink && (
        <SectionMoreLink href={page.slug} label={page.verMasLabel} class="mt-8 px-0" />
      )
    }
  </div>
</section>
