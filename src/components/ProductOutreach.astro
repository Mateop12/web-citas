---
import SectionHeader from './ui/SectionHeader.astro';

const campaigns = [
  {
    label: 'Demanda inducida',
    title: 'Activa pacientes que aún no han agendado',
    description:
      'Segmenta por EPS, edad, historial clínico o especialidad y lanza invitaciones automáticas a controles, tamizajes o consultas con cupo disponible. Tu call center deja de marcar listas manualmente.',
    outcomes: [
      'Campañas programadas por servicio, sede o población',
      'Enlaces directos al portal de autoagendamiento',
      'Seguimiento de aperturas, respuestas y citas generadas',
    ],
    accent: 'from-primary/10 to-primary/5',
    border: 'border-primary/20',
    tag: 'text-primary',
  },
  {
    label: 'Demanda insatisfecha',
    title: 'Recupera pacientes que no encontraron cupo',
    description:
      'Cuando un paciente busca cita y no hay disponibilidad, entra a lista de espera. GEN.AI le avisa por WhatsApp, SMS o correo en cuanto se libera un espacio — antes de que busque en otra institución.',
    outcomes: [
      'Captura automática al fallar la búsqueda de disponibilidad',
      'Recontacto multicanal cuando se abre un cupo',
      'Priorización por antigüedad, urgencia o tipo de servicio',
    ],
    accent: 'from-secondary/10 to-secondary/5',
    border: 'border-secondary/20',
    tag: 'text-secondary',
  },
];

const channels = [
  {
    name: 'WhatsApp',
    summary: 'Conversaciones con IA para agendar, confirmar y reprogramar citas.',
    uses: ['Autoagendamiento 24/7', 'Confirmaciones y recordatorios', 'Campañas con enlace directo'],
    icon: 'whatsapp',
    tint: 'bg-[#0a5c54]/10 text-[#0a5c54]',
  },
  {
    name: 'SMS',
    summary: 'Alertas puntuales con alta tasa de lectura en el celular del paciente.',
    uses: ['Recordatorios de cita', 'Aviso de cupo liberado', 'Campañas de demanda inducida'],
    icon: 'sms',
    tint: 'bg-primary/10 text-primary',
  },
  {
    name: 'Correo',
    summary: 'Comunicaciones detalladas con instrucciones y trazabilidad institucional.',
    uses: ['Confirmación con recomendaciones', 'Instrucciones pre-consulta', 'Campañas segmentadas por EPS'],
    icon: 'email',
    tint: 'bg-secondary/10 text-secondary',
  },
];

const flow = [
  { label: 'Segmentación', detail: 'EPS, especialidad, sede o historial' },
  { label: 'Contacto', detail: 'WhatsApp, SMS o correo' },
  { label: 'Agendamiento', detail: 'Portal web, móvil o chat' },
];
---

<section class="section-padding border-t border-line/60 bg-surface/50" aria-label="Campañas de demanda y contactabilidad multicanal">
  <div class="container-custom">
    <SectionHeader
      badge="Captación y contactabilidad"
      title="Más pacientes agendados, sin ampliar tu call center"
      description="GEN.AI no solo recibe citas: activa demanda inducida, recupera demanda insatisfecha y mantiene al paciente informado por WhatsApp, SMS y correo — todo de forma automatizada y trazable."
      align="left"
    />

    <!-- Flujo automatizado -->
    <div class="mt-12 overflow-hidden rounded-2xl border border-line bg-white p-5 sm:p-6" data-animate>
      <p class="eyebrow mb-5">Cómo se conecta con tu operación</p>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-stretch">
        {flow.map((step, i) => (
          <div class="flex flex-1 items-center gap-3">
            {i > 0 && (
              <svg class="hidden h-5 w-5 shrink-0 text-secondary sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            )}
            <div class="flex-1 rounded-xl border border-line bg-surface/40 px-4 py-4">
              <p class="font-display text-sm font-semibold text-ink">{step.label}</p>
              <p class="mt-1 text-xs leading-relaxed text-muted">{step.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Campañas -->
    <div class="mt-14 grid gap-6 lg:grid-cols-2">
      {campaigns.map((campaign) => (
        <article
          class={`rounded-2xl border ${campaign.border} bg-gradient-to-br ${campaign.accent} p-6 sm:p-8`}
          data-animate
        >
          <p class={`eyebrow mb-3 ${campaign.tag}`}>{campaign.label}</p>
          <h3 class="font-display text-xl font-semibold text-ink sm:text-2xl">
            {campaign.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-muted sm:text-base">{campaign.description}</p>
          <ul class="mt-6 space-y-2.5">
            {campaign.outcomes.map((outcome) => (
              <li class="flex items-start gap-2.5 text-sm text-muted">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-secondary" aria-hidden="true"></span>
                {outcome}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <!-- Canales -->
    <div class="mt-16">
      <div class="max-w-2xl" data-animate>
        <p class="eyebrow mb-4">Contactabilidad multicanal</p>
        <h3 class="font-display text-2xl font-bold tracking-tight text-ink sm:text-3xl">
          Un mensaje, el canal que tu paciente prefiera
        </h3>
        <p class="mt-4 text-base leading-relaxed text-muted">
          Confirmaciones, recordatorios y campañas salen por WhatsApp, SMS o correo según la regla que definas.
          Mismo contenido, distintos puntos de contacto — integrado con tu portal web, panel administrativo e
          interoperabilidad con historia clínica.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {channels.map((channel) => (
          <article class="flex flex-col rounded-2xl border border-line bg-white p-6 shadow-sm" data-animate>
            <div class={`mb-4 flex h-11 w-11 items-center justify-center rounded-xl ${channel.tint}`}>
              {
                channel.icon === 'whatsapp' && (
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                )
              }
              {
                channel.icon === 'sms' && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 01-4-.8L3 20l1.8-4.2A8.8 8.8 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                )
              }
              {
                channel.icon === 'email' && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )
              }
            </div>
            <h4 class="font-display text-lg font-semibold text-ink">{channel.name}</h4>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{channel.summary}</p>
            <ul class="mt-5 space-y-2 border-t border-line/80 pt-4">
              {channel.uses.map((use) => (
                <li class="text-xs text-muted">{use}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
